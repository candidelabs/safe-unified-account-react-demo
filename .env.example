# Destination-only chains (recipient can receive USDC here via Across fill;
# the Safe doesn't run userOps on these chains).

# DEST CHAIN 1 — Polygon Amoy
# Verify: confirm Across testnet supports Amoy as a destination, and that
# this USDC contract is the one Across routes to. If not, comment this block.
VITE_DEST_CHAIN1_ID=80002
VITE_DEST_CHAIN1_NAME=Polygon Amoy
VITE_DEST_CHAIN1_JSON_RPC_PROVIDER=https://polygon-amoy-bor-rpc.publicnode.com
