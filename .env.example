# ───────────────────────────────────────────────────────────────────────
# Safe Unified Account demo — Across bridge configuration
#
# Two presets are shown below. Uncomment ONE.
# ───────────────────────────────────────────────────────────────────────

# # UI label for the bridged token. Defaults to "USDT" if unset.
# VITE_TOKEN_SYMBOL=USDT

# # Across REST API base. Defaults to mainnet (app.across.to) if unset.
# # Testnet routes (Sepolia family) live on testnet.across.to instead.
# VITE_ACROSS_API_BASE=https://app.across.to/api

# # ═══════════════════════════════════════════════════════════════════════
# # PRESET A — Mainnet USDT (Arbitrum + Optimism + Base)
# # Across SpokePool addresses: https://docs.across.to/reference/contract-addresses
# # ═══════════════════════════════════════════════════════════════════════

# # CHAIN 1 — Arbitrum One
# VITE_CHAIN1_ID=42161
# VITE_CHAIN1_NAME=Arbitrum
# VITE_CHAIN1_BUNDLER_URL=https://api.candide.dev/public/v3/42161
# VITE_CHAIN1_PAYMASTER_URL=https://api.candide.dev/public/v3/42161
# VITE_CHAIN1_SPONSORSHIP_POLICY_ID=
# VITE_CHAIN1_JSON_RPC_PROVIDER=https://arb1.arbitrum.io/rpc
# VITE_CHAIN1_EXPLORER_URL=https://arbiscan.io
# VITE_CHAIN1_TOKEN=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
# VITE_CHAIN1_TOKEN_DECIMALS=6
# VITE_CHAIN1_SPOKE_POOL=0xe35e9842fceaCA96570B734083f4a58e8F7C5f2A

# # CHAIN 2 — Optimism
# VITE_CHAIN2_ID=10
# VITE_CHAIN2_NAME=Optimism
# VITE_CHAIN2_BUNDLER_URL=https://api.candide.dev/public/v3/10
# VITE_CHAIN2_PAYMASTER_URL=https://api.candide.dev/public/v3/10
# VITE_CHAIN2_SPONSORSHIP_POLICY_ID=
# VITE_CHAIN2_JSON_RPC_PROVIDER=https://mainnet.optimism.io
# VITE_CHAIN2_EXPLORER_URL=https://optimistic.etherscan.io
# VITE_CHAIN2_TOKEN=0x94b008aA00579c1307B0EF2c499aD98a8ce58e58
# VITE_CHAIN2_TOKEN_DECIMALS=6
# VITE_CHAIN2_SPOKE_POOL=0x6f26Bf09B1C792e3228e5467807a900A503c0281

# # CHAIN 3 — Base
# VITE_CHAIN3_ID=8453
# VITE_CHAIN3_NAME=Base
# VITE_CHAIN3_BUNDLER_URL=https://api.candide.dev/public/v3/8453
# VITE_CHAIN3_PAYMASTER_URL=https://api.candide.dev/public/v3/8453
# VITE_CHAIN3_SPONSORSHIP_POLICY_ID=
# VITE_CHAIN3_JSON_RPC_PROVIDER=https://mainnet.base.org
# VITE_CHAIN3_EXPLORER_URL=https://basescan.org
# VITE_CHAIN3_TOKEN=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
# VITE_CHAIN3_TOKEN_DECIMALS=6
# VITE_CHAIN3_SPOKE_POOL=0x09aea4b2242abC8bb4BB78D537A67a245A7bEC64

# # Destination-only chains (recipient can receive USDT here via Across fill;
# # the Safe doesn't run userOps on these chains).

# # DEST CHAIN 1 — Ethereum mainnet
# VITE_DEST_CHAIN1_ID=1
# VITE_DEST_CHAIN1_NAME=Ethereum
# VITE_DEST_CHAIN1_JSON_RPC_PROVIDER=https://ethereum-rpc.publicnode.com
# VITE_DEST_CHAIN1_EXPLORER_URL=https://etherscan.io
# VITE_DEST_CHAIN1_TOKEN=0xdAC17F958D2ee523a2206206994597C13D831ec7
# VITE_DEST_CHAIN1_TOKEN_DECIMALS=6

# # DEST CHAIN 2 — Polygon
# VITE_DEST_CHAIN2_ID=137
# VITE_DEST_CHAIN2_NAME=Polygon
# VITE_DEST_CHAIN2_JSON_RPC_PROVIDER=https://polygon-bor-rpc.publicnode.com
# VITE_DEST_CHAIN2_EXPLORER_URL=https://polygonscan.com
# VITE_DEST_CHAIN2_TOKEN=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# VITE_DEST_CHAIN2_TOKEN_DECIMALS=6


# ═══════════════════════════════════════════════════════════════════════
# PRESET B — Testnet USDC (Sepolia + Optimism Sepolia + Arbitrum Sepolia)
# Uncomment, comment out PRESET A, set VITE_TOKEN_SYMBOL=USDC AND set
# VITE_ACROSS_API_BASE=https://testnet.across.to/api (testnet routes live
# on a different host from mainnet).
# Across SpokePool addresses: https://docs.across.to/reference/contract-addresses-testnet
# ═══════════════════════════════════════════════════════════════════════

VITE_TOKEN_SYMBOL=USDC
VITE_ACROSS_API_BASE=https://testnet.across.to/api

